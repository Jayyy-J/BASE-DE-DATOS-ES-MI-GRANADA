# ── Copia este archivo como  .env  y llena los valores ──────────────────────

# 1. Clave de API de Anthropic (Claude)
#    Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 2. Token de autenticación de Twilio
#    Obtener en: https://console.twilio.com → Account Info
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 3. Puerto del servidor (Railway/Render lo asignan automáticamente)
PORT=5000
